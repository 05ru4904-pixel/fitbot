# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Ключ API polza.ai (агрегатор, модель google/gemini-2.5-flash-lite)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL. На Railway подставляется автоматически из плагина Postgres.
# Локально: postgresql://user:password@localhost:5432/fitbot
DATABASE_URL=postgresql://user:password@localhost:5432/fitbot

# Публичный HTTPS-URL Mini App (заканчивается на /app).
# Пока не задан — кнопка дневника в боте скрыта. Заполняется после деплоя.
WEBAPP_URL=https://your-app.up.railway.app/app
